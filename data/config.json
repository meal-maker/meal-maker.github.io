{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-reasoner",
    "api_key_env": "OPENAI_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.3,
    "max_tokens": 4096,
    "languages": ["en", "zh"]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "torvalds",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openclaw",
        "repo": "openclaw",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": false,
        "category": "ai-tools"
      },
      {
        "name": "阮一峰的个人网站",
        "url": "http://feeds.feedburner.com/ruanyifeng",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "鸟窝",
        "url": "https://colobu.com/atom.xml",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "ClaudeAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "ChatGPT",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLM",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "openai",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "ArtificialInteligence",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": [
        {
          "username": "iamthatis",
          "enabled": false,
          "sort": "new",
          "fetch_limit": 10
        }
      ],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  }
}